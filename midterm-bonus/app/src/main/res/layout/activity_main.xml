<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_dark"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- ── Header ── -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Compound Interest"
            android:textColor="@color/accent"
            android:textSize="13sp"
            android:textAllCaps="true"
            android:letterSpacing="0.15"
            android:layout_marginBottom="2dp"
            android:fontFamily="@font/inter" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Calculator"
            android:textColor="@color/text_primary"
            android:textSize="28sp"
            android:fontFamily="@font/inter"
            android:layout_marginBottom="4dp" />

        <TextView
            android:id="@+id/tvFormula"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="A = P(1 + r/n)ⁿᵗ"
            android:textColor="@color/text_secondary"
            android:textSize="13sp"
            android:fontFamily="@font/inter"
            android:layout_marginBottom="20dp" />

        <!-- ── Input Card ── -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardBackgroundColor="@color/surface"
            app:cardCornerRadius="16dp"
            app:cardElevation="0dp"
            android:layout_marginBottom="12dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <!-- Calculate Spinner -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="CALCULATE"
                    android:textColor="@color/text_tertiary"
                    android:textSize="10sp"
                    android:letterSpacing="0.12"
                    android:fontFamily="@font/inter"
                    android:layout_marginBottom="6dp" />

                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:cardBackgroundColor="@color/input_bg"
                    app:cardCornerRadius="10dp"
                    app:cardElevation="0dp"
                    android:layout_marginBottom="16dp">

                    <Spinner
                        android:id="@+id/spinnerCalculate"
                        android:layout_width="match_parent"
                        android:layout_height="52dp"
                        android:paddingStart="14dp"
                        android:paddingEnd="14dp" />
                </androidx.cardview.widget.CardView>

                <!-- Principal -->
                <LinearLayout
                    android:id="@+id/layoutPrincipal"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:layout_marginBottom="12dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="PRINCIPAL (P)"
                        android:textColor="@color/text_tertiary"
                        android:textSize="10sp"
                        android:letterSpacing="0.12"
                        android:fontFamily="@font/inter"
                        android:layout_marginBottom="6dp" />

                    <androidx.cardview.widget.CardView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        app:cardBackgroundColor="@color/input_bg"
                        app:cardCornerRadius="10dp"
                        app:cardElevation="0dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="52dp"
                            android:orientation="horizontal"
                            android:gravity="center_vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="₱"
                                android:textColor="@color/accent"
                                android:textSize="16sp"
                                android:fontFamily="@font/inter"
                                android:paddingStart="14dp"
                                android:paddingEnd="8dp" />

                            <EditText
                                android:id="@+id/etPrincipal"
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:background="@null"
                                android:hint="10,000.00"
                                android:inputType="numberDecimal"
                                android:textColor="@color/text_primary"
                                android:textColorHint="@color/text_tertiary"
                                android:textSize="15sp"
                                android:fontFamily="@font/inter"
                                android:paddingEnd="14dp" />
                        </LinearLayout>
                    </androidx.cardview.widget.CardView>
                </LinearLayout>

                <!-- Annual Rate -->
                <LinearLayout
                    android:id="@+id/layoutRate"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:layout_marginBottom="12dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="ANNUAL RATE (R)"
                        android:textColor="@color/text_tertiary"
                        android:textSize="10sp"
                        android:letterSpacing="0.12"
                        android:fontFamily="@font/inter"
                        android:layout_marginBottom="6dp" />

                    <androidx.cardview.widget.CardView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        app:cardBackgroundColor="@color/input_bg"
                        app:cardCornerRadius="10dp"
                        app:cardElevation="0dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="52dp"
                            android:orientation="horizontal"
                            android:gravity="center_vertical">

                            <EditText
                                android:id="@+id/etRate"
                                android:layout_width="0dp"
                                android:layout_height="match_parent"
                                android:layout_weight="1"
                                android:background="@null"
                                android:hint="3.875"
                                android:inputType="numberDecimal"
                                android:textColor="@color/text_primary"
                                android:textColorHint="@color/text_tertiary"
                                android:textSize="15sp"
                                android:fontFamily="@font/inter"
                                android:paddingStart="14dp" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="%"
                                android:textColor="@color/accent"
                                android:textSize="16sp"
                                android:fontFamily="@font/inter"
                                android:paddingStart="8dp"
                                android:paddingEnd="14dp" />
                        </LinearLayout>
                    </androidx.cardview.widget.CardView>
                </LinearLayout>

                <!-- Compound Frequency -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="COMPOUND FREQUENCY (n)"
                    android:textColor="@color/text_tertiary"
                    android:textSize="10sp"
                    android:letterSpacing="0.12"
                    android:fontFamily="@font/inter"
                    android:layout_marginBottom="6dp" />

                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:cardBackgroundColor="@color/input_bg"
                    app:cardCornerRadius="10dp"
                    app:cardElevation="0dp"
                    android:layout_marginBottom="12dp">

                    <Spinner
                        android:id="@+id/spinnerCompound"
                        android:layout_width="match_parent"
                        android:layout_height="52dp"
                        android:paddingStart="14dp"
                        android:paddingEnd="14dp" />
                </androidx.cardview.widget.CardView>

                <!-- Time -->
                <LinearLayout
                    android:id="@+id/layoutTime"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:layout_marginBottom="12dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="TIME (t in years)"
                        android:textColor="@color/text_tertiary"
                        android:textSize="10sp"
                        android:letterSpacing="0.12"
                        android:fontFamily="@font/inter"
                        android:layout_marginBottom="2dp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="ex. 1.5 yr = 18 months"
                        android:textColor="@color/text_tertiary"
                        android:textSize="10sp"
                        android:fontFamily="@font/inter"
                        android:layout_marginBottom="6dp" />

                    <androidx.cardview.widget.CardView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        app:cardBackgroundColor="@color/input_bg"
                        app:cardCornerRadius="10dp"
                        app:cardElevation="0dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="52dp"
                            android:orientation="horizontal"
                            android:gravity="center_vertical">

                            <EditText
                                android:id="@+id/etTime"
                                android:layout_width="0dp"
                                android:layout_height="match_parent"
                                android:layout_weight="1"
                                android:background="@null"
                                android:hint="7.5"
                                android:inputType="numberDecimal"
                                android:textColor="@color/text_primary"
                                android:textColorHint="@color/text_tertiary"
                                android:textSize="15sp"
                                android:fontFamily="@font/inter"
                                android:paddingStart="14dp" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="yr"
                                android:textColor="@color/accent"
                                android:textSize="16sp"
                                android:fontFamily="@font/inter"
                                android:paddingStart="8dp"
                                android:paddingEnd="14dp" />
                        </LinearLayout>
                    </androidx.cardview.widget.CardView>
                </LinearLayout>

                <!-- Total (A or I) -->
                <LinearLayout
                    android:id="@+id/layoutTotal"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:layout_marginBottom="12dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="TOTAL AMOUNT (A) or INTEREST (I)"
                        android:textColor="@color/text_tertiary"
                        android:textSize="10sp"
                        android:letterSpacing="0.12"
                        android:fontFamily="@font/inter"
                        android:layout_marginBottom="6dp" />

                    <androidx.cardview.widget.CardView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        app:cardBackgroundColor="@color/input_bg"
                        app:cardCornerRadius="10dp"
                        app:cardElevation="0dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="52dp"
                            android:orientation="horizontal"
                            android:gravity="center_vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="₱"
                                android:textColor="@color/accent"
                                android:textSize="16sp"
                                android:fontFamily="@font/inter"
                                android:paddingStart="14dp"
                                android:paddingEnd="8dp" />

                            <EditText
                                android:id="@+id/etTotal"
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:background="@null"
                                android:hint="13,366.37"
                                android:inputType="numberDecimal"
                                android:textColor="@color/text_primary"
                                android:textColorHint="@color/text_tertiary"
                                android:textSize="15sp"
                                android:fontFamily="@font/inter"
                                android:paddingEnd="14dp" />
                        </LinearLayout>
                    </androidx.cardview.widget.CardView>
                </LinearLayout>

                <!-- Buttons -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginTop="4dp">

                    <Button
                        android:id="@+id/btnClear"
                        android:layout_width="0dp"
                        android:layout_height="52dp"
                        android:layout_weight="1"
                        android:text="Clear"
                        android:textColor="@color/text_primary"
                        android:background="@drawable/btn_outline"
                        android:textSize="14sp"
                        android:fontFamily="@font/inter"
                        android:layout_marginEnd="8dp" />

                    <Button
                        android:id="@+id/btnCalculate"
                        android:layout_width="0dp"
                        android:layout_height="52dp"
                        android:layout_weight="2"
                        android:text="Calculate"
                        android:textColor="@color/bg_dark"
                        android:background="@drawable/btn_primary"
                        android:textSize="14sp"
                        android:fontFamily="@font/inter" />
                </LinearLayout>

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- ── Result Card ── -->
        <androidx.cardview.widget.CardView
            android:id="@+id/cardResult"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardBackgroundColor="@color/surface"
            app:cardCornerRadius="16dp"
            app:cardElevation="0dp"
            android:layout_marginBottom="12dp"
            android:visibility="gone">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView
                    android:id="@+id/tvResultLabel"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="@color/text_tertiary"
                    android:textSize="10sp"
                    android:letterSpacing="0.12"
                    android:fontFamily="@font/inter"
                    android:text="RESULT"
                    android:layout_marginBottom="4dp" />

                <TextView
                    android:id="@+id/tvResultValue"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="@color/accent"
                    android:textSize="36sp"
                    android:fontFamily="@font/inter"
                    android:layout_marginBottom="12dp" />

                <!-- Divider -->
                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="@color/divider"
                    android:layout_marginBottom="12dp" />

                <TextView
                    android:id="@+id/tvPrincipalResult"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="@color/text_secondary"
                    android:textSize="14sp"
                    android:fontFamily="@font/inter"
                    android:layout_marginBottom="4dp" />

                <TextView
                    android:id="@+id/tvInterestResult"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="@color/text_secondary"
                    android:textSize="14sp"
                    android:fontFamily="@font/inter"
                    android:layout_marginBottom="16dp" />

                <!-- Chart -->
                <com.github.mikephil.charting.charts.LineChart
                    android:id="@+id/lineChart"
                    android:layout_width="match_parent"
                    android:layout_height="200dp"
                    android:layout_marginBottom="16dp" />

                <!-- Divider -->
                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="@color/divider"
                    android:layout_marginBottom="12dp" />

                <!-- Steps -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="CALCULATION STEPS"
                    android:textColor="@color/text_tertiary"
                    android:textSize="10sp"
                    android:letterSpacing="0.12"
                    android:fontFamily="@font/inter"
                    android:layout_marginBottom="8dp" />

                <TextView
                    android:id="@+id/tvSteps"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textColor="@color/text_secondary"
                    android:textSize="12sp"
                    android:fontFamily="@font/inter"
                    android:lineSpacingMultiplier="1.5"
                    android:background="@drawable/bg_code"
                    android:padding="12dp" />

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- ── Insight Card ── -->
        <androidx.cardview.widget.CardView
            android:id="@+id/cardInsight"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardBackgroundColor="@color/surface_accent"
            app:cardCornerRadius="16dp"
            app:cardElevation="0dp"
            android:layout_marginBottom="24dp"
            android:visibility="gone">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView
                    android:id="@+id/tvInsight"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textColor="@color/text_primary"
                    android:textSize="13sp"
                    android:fontFamily="@font/inter"
                    android:lineSpacingMultiplier="1.6"
                    android:layout_marginBottom="16dp" />

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="@color/divider"
                    android:layout_marginBottom="12dp" />

                <TextView
                    android:id="@+id/tvWhatIf"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textColor="@color/text_primary"
                    android:textSize="13sp"
                    android:fontFamily="@font/inter"
                    android:lineSpacingMultiplier="1.6" />
            </LinearLayout>
        </androidx.cardview.widget.CardView>

    </LinearLayout>
</ScrollView>
